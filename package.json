{
  "name": "drone-simulator",
  "version": "1.0.0",
  "author": "Olivier BERNARD",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.2.2",
    "@types/bun": "latest",
    "@types/three": "^0.182.0",
    "@typescript-eslint/eslint-plugin": "^8.55.0",
    "@typescript-eslint/parser": "^8.55.0",
    "@vitest/coverage-v8": "^4.0.18",
    "@vitest/ui": "^4.0.18",
    "eslint": "^10.0.0",
    "fake-indexeddb": "^6.0.0",
    "happy-dom": "^20.6.1",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.2.2",
    "typescript-eslint": "^8.55.0",
    "vite": "^7.3.1",
    "vite-plugin-solid": "^2.11.10",
    "vitest": "^4.0.18"
  },
  "peerDependencies": {
    "typescript": "^5.9.3"
  },
  "description": "A static SolidJS web application for drone simulation",
  "license": "MIT",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "type-check": "tsc --noEmit",
    "lint": "eslint src --ext .ts,.tsx && bun run type-check",
    "lint:fix": "eslint src --ext .ts,.tsx --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,css,json,md}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css,json,md}\""
  },
  "type": "module",
  "dependencies": {
    "@mapbox/vector-tile": "^2.0.4",
    "@turf/area": "^7.3.4",
    "@turf/bearing": "^7.3.4",
    "@turf/boolean-contains": "^7.3.4",
    "@turf/boolean-point-in-polygon": "^7.3.4",
    "@turf/centroid": "^7.3.4",
    "@turf/distance": "^7.3.4",
    "@turf/helpers": "^7.3.4",
    "@turf/length": "^7.3.4",
    "@turf/line-slice-along": "^7.3.4",
    "@turf/point-grid": "^7.3.4",
    "geojson": "^0.5.0",
    "pbf": "^4.0.1",
    "pmtiles": "^4.4.0",
    "solid-icons": "^1.2.0",
    "solid-js": "^1.9.11",
    "three": "^0.160.0"
  }
}
